  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
